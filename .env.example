## Example environment variables for Nails_Nice_py
# Copy to a local `.env` and fill values before deploying.

DJANGO_SECRET_KEY=change-me-to-a-strong-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database (sqlite / postgres / mysql)
DB_ENGINE=sqlite
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=

REDIS_URL=
USE_MANIFEST_STATIC=false
# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database MySQL
DB_ENGINE=django.db.backends.mysql
DB_NAME=nails_nice
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
